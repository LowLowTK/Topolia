---
// src/components/studio/RssItem.astro
export interface Props {
  title: string;
  link: string;
  pubDate: string;
  excerpt: string;
  sourceName: string;
  sourceLang: string;
}

const { title, link, pubDate, excerpt, sourceName, sourceLang } = Astro.props;

const LANG_FLAGS: Record<string, string> = {
  EN: '🇬🇧',
  FR: '🇫🇷',
  DE: '🇩🇪',
  JP: '🇯🇵',
  SE: '🇸🇪',
};

const flag = LANG_FLAGS[sourceLang] ?? '🌐';

const dateFormatted = pubDate
  ? new Date(pubDate).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })
  : '';
---

<li class="rss-item">
  <div class="rss-item__left">
    <span class="rss-item__flag">{flag}</span>
    <span class="rss-item__source">{sourceName}</span>
  </div>

  <div class="rss-item__center">
    <a
      class="rss-item__title"
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      title={excerpt || title}
    >
      {title}
    </a>
  </div>

  <div class="rss-item__right">
    {dateFormatted && <span class="rss-item__date">{dateFormatted}</span>}
    <button
      class="rss-item__btn rss-item__btn--save"
      data-title={title}
      data-url={link}
      data-lang={sourceLang}
      data-source={sourceName}
      data-excerpt={excerpt}
      aria-label="Sauvegarder ce sujet"
      title="Sauvegarder"
    >
      💾
    </button>
    <button
      class="rss-item__btn rss-item__btn--prompt"
      data-title={title}
      data-url={link}
      aria-label="Préparer le prompt"
    >
      ✨ Prompt
    </button>
  </div>
</li>

<style>
  .rss-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--hairline);
    background: var(--surface);
    transition: background 0.12s;
  }

  .rss-item:hover {
    background: var(--bg-alt);
  }

  .rss-item:last-child {
    border-bottom: none;
  }

  /* Colonne gauche — source */
  .rss-item__left {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 190px;
    max-width: 190px;
    flex-shrink: 0;
  }

  .rss-item__flag {
    font-size: 1rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .rss-item__source {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.02em;
  }

  /* Colonne centre — titre */
  .rss-item__center {
    flex: 1;
    min-width: 0;
  }

  .rss-item__title {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.4;
    transition: color 0.12s;
  }

  .rss-item__title:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Colonne droite — date + boutons */
  .rss-item__right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .rss-item__date {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-light);
    white-space: nowrap;
    min-width: 44px;
    text-align: right;
  }

  .rss-item__btn {
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.8rem;
    white-space: nowrap;
    transition:
      background 0.12s,
      opacity 0.12s;
  }

  .rss-item__btn--save {
    background: transparent;
    border: 1px solid var(--hairline-strong);
    color: var(--ink-muted);
    padding: 4px 8px;
    font-size: 1rem;
  }

  .rss-item__btn--save:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .rss-item__btn--prompt {
    background: var(--accent);
    color: #fff;
    padding: 5px 12px;
  }

  .rss-item__btn--prompt:hover {
    opacity: 0.85;
  }

  @media (max-width: 640px) {
    .rss-item__left {
      min-width: 28px;
      max-width: 28px;
    }
    .rss-item__source,
    .rss-item__date {
      display: none;
    }
  }
</style>
