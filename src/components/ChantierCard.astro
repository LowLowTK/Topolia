---
import type { CollectionEntry } from 'astro:content';
import HeroPlaceholder from './HeroPlaceholder.astro';

interface Props {
  entry: CollectionEntry<'chantiers'>;
}
const { entry } = Astro.props;
const { title, surface, materiel, tags } = entry.data;
---

<a href={`/chantiers/${entry.id}/`} class="chantier-card">
  <div class="chantier-card-visual">
    <HeroPlaceholder title={title} category="Retour de chantier" variant="card" palette="warm" />
    {surface && <span class="chantier-surface-badge">{surface}</span>}
  </div>

  <div class="chantier-card-body">
    {
      materiel.length > 0 && (
        <ul class="chantier-materiel">
          {materiel.slice(0, 3).map((m) => (
            <li>{m}</li>
          ))}
        </ul>
      )
    }
    {
      tags.length > 0 && (
        <ul class="chantier-tags">
          {tags.map((tag) => (
            <li>#{tag}</li>
          ))}
        </ul>
      )
    }
  </div>
</a>

<style>
  .chantier-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    transition:
      border-color 0.15s,
      box-shadow 0.15s,
      transform 0.15s;
  }
  .chantier-card:hover {
    border-color: var(--amber);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .chantier-card-visual {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--bg-dark);
  }

  .chantier-surface-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 4px 10px;
    background: rgba(15, 23, 42, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: rgba(245, 158, 11, 0.95);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 6px;
    z-index: 2;
  }

  .chantier-card-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 18px 20px 20px;
    background: var(--bg-warm);
  }

  .chantier-materiel {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
  }
  .chantier-materiel li {
    padding: 4px 9px;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 6px;
    font-size: 0.78rem;
    color: var(--ink-2);
  }

  .chantier-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
  }
  .chantier-tags li {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
  }
</style>
