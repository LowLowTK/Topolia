---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import Comments from '../../components/Comments.astro';
import { getCollection, render } from 'astro:content';
import { publishedOnly } from '../../lib/content-helpers';
import { readingTime } from '../../lib/reading-time';

export async function getStaticPaths() {
  const articles = publishedOnly(await getCollection('articles'));
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const minutes = readingTime(entry.body ?? '');

const allArticles = publishedOnly(await getCollection('articles'));
const related = allArticles
  .filter((a) => a.data.category === entry.data.category && a.id !== entry.id)
  .slice(0, 3)
  .map((a) => ({
    href: `/articles/${a.id}/`,
    label: a.data.title,
    type: 'article' as const,
  }));

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://topolia.fr';

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: entry.data.title,
  description: entry.data.excerpt,
  datePublished: entry.data.date.toISOString(),
  image: `${siteUrl}${entry.data.heroImage}`,
  author: {
    '@type': 'Person',
    name: 'Loïc',
    jobTitle: 'Géomètre-expert',
    url: `${siteUrl}/a-propos`,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Topolia',
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${siteUrl}/articles/${entry.id}/` },
};

const jsonLd = JSON.stringify(jsonLdArticle);
---

<ArticleLayout
  title={entry.data.title}
  subtitle={entry.data.subtitle}
  description={entry.data.excerpt}
  date={entry.data.date}
  category={entry.data.category}
  author={entry.data.author}
  heroImage={entry.data.heroImage}
  heroImageAlt={entry.data.heroImageAlt}
  readingTime={minutes}
  headings={headings}
  jsonLd={jsonLd}
>
  <Content />
  <Comments slot="comments" contentId={entry.id} contentType="article" />
  <RelatedContent slot="related" title="À lire aussi" items={related} />
</ArticleLayout>
